APP_NAME="FreshBasket"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=grocery_store
DB_USERNAME=root
DB_PASSWORD=

# ── Cache / Queue ─────────────────────────────────────────────
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

# ── Session ───────────────────────────────────────────────────
# Use 'file' not 'database' to avoid needing the sessions table
# API routes use stateless Bearer tokens so sessions are only
# used by the web guard (not relevant for this project)
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── Mail ──────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@freshbasket.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Stripe ────────────────────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_test_REPLACE_WITH_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET=sk_test_REPLACE_WITH_YOUR_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ── PayPal ────────────────────────────────────────────────────
# Create sandbox app at: https://developer.paypal.com
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=REPLACE_WITH_YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_YOUR_PAYPAL_CLIENT_SECRET

# ── Frontend / CORS ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,127.0.0.1:5173

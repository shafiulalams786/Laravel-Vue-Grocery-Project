# ── API Base URL ──────────────────────────────────────────────
# In development, Vite proxies /api to http://localhost:8000
# so no CORS issues. Use the relative path below:
VITE_API_URL=/api/v1

# In production, change to your actual API domain:
# VITE_API_URL=https://api.yourdomain.com/api/v1

# ── Stripe (publishable key only — secret stays on server) ───
VITE_STRIPE_KEY=pk_test_REPLACE_WITH_YOUR_PUBLISHABLE_KEY

# ── PayPal (client ID only) ───────────────────────────────────
VITE_PAYPAL_CLIENT_ID=REPLACE_WITH_YOUR_PAYPAL_CLIENT_ID
